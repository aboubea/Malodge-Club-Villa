# Database
DATABASE_URL="postgresql://user:password@neon-host/mahodge_db?sslmode=require"

# JWT
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Backend
PORT=3001
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:3001

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mahodge-files
R2_PUBLIC_URL=

# Resend (emails)
RESEND_API_KEY=
MAIL_FROM="Mahodge Club Villa <noreply@mahodge.com>"
APP_URL=http://localhost:5173

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
